# Example env for backend when running in Docker (same network as postgres from docker-compose).
# Use: docker run ... --env-file backend/.env -e DB_HOST=postgres ...
# Or copy and set DB_HOST=postgres in your .env when deploying.
PORT=4000
DB_HOST=postgres
DB_PORT=5432
DB_NAME=million_miles
DB_USER=app
DB_PASSWORD=app_secret
JWT_SECRET=your-secret-key
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123
CORS_ORIGIN=http://localhost:3000
