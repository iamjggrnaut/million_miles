# Lightweight worker image without Argos Translate (~150MB vs several GB).
# Translation disabled: description/dealer/model stay in Japanese.
# Build: docker build -f Dockerfile.slim -t million-worker:slim ./worker
# Run with: -e LOCAL_TRANSLATE_ENABLED=false (optional, already default in image)
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production LOCAL_TRANSLATE_ENABLED=false
COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=builder /app/dist ./dist
USER node
CMD ["node", "dist/index.js"]
